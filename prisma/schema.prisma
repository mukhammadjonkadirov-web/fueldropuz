generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Order {
  id      String @id @default(cuid())
  orderId String @unique

  name  String
  phone String

  city        String?
  address     String?
  coordinates String? // JSON stringified { lat, lng }

  fuelType String?
  liters   String?

  // String-based statuses for SQLite (no native enums)
  paymentMethod String   // "cash" | "card" | "payment_link"
  paymentStatus String   @default("pending") // "pending" | "paid" | "failed"
  status        String   @default("new")     // "new" | "accepted" | "on_the_way" | "delivered"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


